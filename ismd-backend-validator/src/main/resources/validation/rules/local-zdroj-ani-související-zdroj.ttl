@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix slovníky: <https://slovník.gov.cz/generický/datový-slovník-ofn-slovníků/pojem/> .

# Warning rule: Concept has neither source nor related source
<https://slovník.gov.cz/shacl/lokální/zdroj-ani-související-zdroj>
    a sh:NodeShape ;
    sh:targetClass slovníky:pojem ;
    sh:name "Zdroj ani související zdroj"@cs ;
    sh:description "Reports when concept has neither defining nor related source (legislative or non-legislative)" ;
    sh:message "Pojem nemá vyplněný atribut zdroj ani související zdroj"@cs ;
    sh:severity sh:Warning ;

    sh:sparql [
        sh:select """
            PREFIX slovníky: <https://slovník.gov.cz/generický/datový-slovník-ofn-slovníků/pojem/>

            SELECT $this
            WHERE {
                $this a slovníky:pojem .
                FILTER(
                    NOT EXISTS { $this slovníky:definující-ustanovení ?du . } &&
                    NOT EXISTS { $this slovníky:související-ustanovení ?su . } &&
                    NOT EXISTS { $this slovníky:definující-nelegislativní-zdroj ?dnz . } &&
                    NOT EXISTS { $this slovníky:související-nelegislativní-zdroj ?snz . }
                )
            }
        """ ;
    ] .
