@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix slovníky: <https://slovník.gov.cz/generický/datový-slovník-ofn-slovníků/pojem/> .
@prefix a104: <https://slovník.gov.cz/agendový/104/pojem/> .
@prefix vsgov: <https://slovník.gov.cz/veřejný-sektor/pojem/> .
@prefix z111: <https://slovník.gov.cz/legislativní/sbírka/111/2009/pojem/> .

# Info rule: Concept does not have RPP/360 characteristics
<https://slovník.gov.cz/shacl/lokální/pojem-nemá-charakteristiky-rpp>
    a sh:NodeShape ;
    sh:targetClass slovníky:pojem ;
    sh:name "Charakteristiky RPP/360 pojmu"@cs ;
    sh:description "Reports when concept does not have RPP/360 characteristics" ;
    sh:message "Pojem nemá vyplněné charakteristiky pro RPP/360"@cs ;
    sh:severity sh:Info ;

    sh:sparql [
        sh:select """
            PREFIX slovníky: <https://slovník.gov.cz/generický/datový-slovník-ofn-slovníků/pojem/>
            PREFIX a104: <https://slovník.gov.cz/agendový/104/pojem/>
            PREFIX vsgov: <https://slovník.gov.cz/veřejný-sektor/pojem/>
            PREFIX z111: <https://slovník.gov.cz/legislativní/sbírka/111/2009/pojem/>

            SELECT $this
            WHERE {
                $this a slovníky:pojem .

                # Concept does not have any RPP/360 characteristics
                FILTER (
                    NOT EXISTS { $this a vsgov:typ-subjektu-práva . } &&
                    NOT EXISTS { $this a vsgov:typ-objektu-práva . } &&
                    NOT EXISTS { $this a z111:neveřejný-údaj . } &&
                    NOT EXISTS { $this a z111:veřejný-údaj . } &&
                    NOT EXISTS { $this a104:je-sdílen-v-propojeném-datovém-fondu ?ppdf . } &&
                    NOT EXISTS { $this slovníky:má-způsob-získání-údaje ?zz . } &&
                    NOT EXISTS { $this slovníky:má-typ-obsahu-údaje ?to . } &&
                    NOT EXISTS { $this slovníky:má-způsob-sdílení-údaje ?zs . } &&
                    NOT EXISTS { $this a104:sdružuje-údaje-vedené-nebo-vytvářené-v-rámci-agendy ?ag . } &&
                    NOT EXISTS { $this a104:údaje-jsou-v-ais ?ais . }
                )
            }
        """ ;
    ] .

# Info rule: Concept has complete RPP characteristics
<https://slovník.gov.cz/shacl/lokální/pojem-má-kompletní-údaje-charakteristiky-rpp>
    a sh:NodeShape ;
    sh:targetClass slovníky:pojem ;
    sh:name "Kompletní údaje RPP charakteristik"@cs ;
    sh:description "Reports when concept has complete RPP characteristics" ;
    sh:message "Pojem má kompletní charakteristiky pro RPP"@cs ;
    sh:severity sh:Info ;

    sh:sparql [
        sh:select """
            PREFIX slovníky: <https://slovník.gov.cz/generický/datový-slovník-ofn-slovníků/pojem/>
            PREFIX a104: <https://slovník.gov.cz/agendový/104/pojem/>
            PREFIX vsgov: <https://slovník.gov.cz/veřejný-sektor/pojem/>
            PREFIX z111: <https://slovník.gov.cz/legislativní/sbírka/111/2009/pojem/>

            SELECT $this
            WHERE {
                # Must be shared in PPDF
                $this a104:je-sdílen-v-propojeném-datovém-fondu true .

                # Must be typ-subjektu-práva OR typ-objektu-práva
                {
                    $this a vsgov:typ-subjektu-práva .
                } UNION {
                    $this a vsgov:typ-objektu-práva .
                }

                # If it's neveřejný-údaj, it must have ustanovení
                FILTER (
                    NOT EXISTS { $this a z111:neveřejný-údaj . } ||
                    EXISTS {
                        $this a z111:neveřejný-údaj .
                        $this z111:je-vymezen-ustanovením-stanovujícím-jeho-neveřejnost ?ustanoveni .
                    }
                )
            }
        """ ;
    ] .
