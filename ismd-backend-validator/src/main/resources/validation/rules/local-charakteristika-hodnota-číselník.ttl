@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix slovníky: <https://slovník.gov.cz/generický/datový-slovník-ofn-slovníků/pojem/> .

# Error rule: Concept characteristic value must be from OFN enumeration
<https://slovník.gov.cz/shacl/lokální/charakteristika-hodnota-číselník>
    a sh:NodeShape ;
    sh:targetClass slovníky:pojem ;
    sh:name "Charakteristika pojmu dle číselníku OFN"@cs ;
    sh:description "Validates that concept characteristics use values from OFN enumerations (e.g. 360/2023)" ;
    sh:message "Charakteristika pojmu neobsahuje hodnotu dle číselníku z OFN (např. 360/2023)"@cs ;
    sh:severity sh:Violation ;

    sh:sparql [
        sh:select """
            PREFIX slovníky: <https://slovník.gov.cz/generický/datový-slovník-ofn-slovníků/pojem/>

            SELECT $this ?value
            WHERE {
                $this a slovníky:pojem .
                {
                    $this slovníky:má-způsob-získání-údaje ?value .
                    FILTER(!STRSTARTS(STR(?value), "https://data.dia.gov.cz/zdroj/číselníky/způsoby-získání-údajů/položky/"))
                } UNION {
                    $this slovníky:má-typ-obsahu-údaje ?value .
                    FILTER(!STRSTARTS(STR(?value), "https://data.dia.gov.cz/zdroj/číselníky/typy-obsahu-údajů/položky/"))
                } UNION {
                    $this slovníky:má-způsob-sdílení-údaje ?value .
                    FILTER(!STRSTARTS(STR(?value), "https://data.dia.gov.cz/zdroj/číselníky/způsoby-sdílení-údajů/položky/"))
                }
            }
        """ ;
    ] .
